pipeline {
    agent any

    stages {

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Start Server') {
            steps {
                bat 'npm start'
            }
        }

    }

    post {
        success {
            echo 'Build SUCCESS'
        }
        failure {
            echo ' Build FAILED'
        }
    }
}